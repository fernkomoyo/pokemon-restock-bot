# Discord Webhook URL for sending restock alerts
# REPLACE this with your actual Discord webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1514472416523587584/5TfuOaKy8p-d7JJjJCxAwhVO9LYJsI07DVHWIY97VZnpjcPOmUjQk5o65i_0muV-GWmi

# Check interval in minutes (Recommended: 5 to 15 to avoid getting IP-banned)
# Note: Only applies in daemon/loop mode, not when run with --once
CHECK_INTERVAL_MINUTES=10

# Set to "live" to check the real website, or "simulated" to run in test/simulation mode
SCRAPER_MODE=live

# Set to "true" to run the check cycle once and then exit (ideal for GitHub Actions cron)
RUN_ONCE=false

# --- SCRAPER API CONFIGURATION (Required for GitHub Actions to bypass DataDome) ---
# Supported values: playwright (default / local only), scraperapi, scrapingant, zenrows, crawlbase
SCRAPER_PROVIDER=playwright

# Enter your Scraper API Key / Token depending on the provider chosen above:
SCRAPER_API_KEY=your-scraper-api-key
SCRAPINGANT_API_KEY=your-scrapingant-api-key
ZENROWS_API_KEY=your-zenrows-api-key
CRAWLBASE_TOKEN=your-crawlbase-token

# Optional: Enable JS rendering on the API side (takes more API credits but handles JS-heavy changes)
SCRAPERAPI_RENDER=false
SCRAPINGANT_JS=false
ZENROWS_JS_RENDER=false
CRAWLBASE_JS=false


